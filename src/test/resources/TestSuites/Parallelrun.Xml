<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Local Test Suite"
       parallel="classes"
       thread-count="4">

    <parameter name="browser" value="chrome"/>
    <parameter name="runmode" value="local"/>

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
        <listener class-name="utils.AllureListener"/>
    </listeners>

    <test name="Regression">

        <classes>

            <class name="modules.login.tests.ConnectLoginTest"/>

            <class name="modules.login.tests.ProfilepicUpdateTest"/>

            <class name="modules.Homepage.DashboardTests.DashboardRedirectionTest"/>

            <class name="modules.Homepage.DashboardTests.BannerTest"/>

        </classes>

    </test>

</suite>