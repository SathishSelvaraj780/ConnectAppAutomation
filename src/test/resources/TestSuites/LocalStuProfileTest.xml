<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Local Test Suite">

    <parameter name="browser" value="chrome"/>
    <parameter name="runmode" value="local"/>

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
        <listener class-name="utils.AllureListener"/>
    </listeners>


    <test name="Student Profile Local Test">

        <classes>

            <class name="modules.StudentProfile.Tests.AttendanceTest"/>

            <class name="modules.StudentProfile.Tests.BasicInfoTest"/>

            <class name="modules.StudentProfile.Tests.ComminicationsTest"/>

            <class name="modules.StudentProfile.Tests.CurriculamTest"/>

            <class name="modules.StudentProfile.Tests.FeeDetailsTest"/>

            <class name="modules.StudentProfile.Tests.OthersLibraryUsageTest"/>

            <class name="modules.StudentProfile.Tests.OthersTabAchievementTest"/>

        </classes>

    </test>

</suite>